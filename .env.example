# Copy this to .env and fill in values
# Never commit .env to git

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/football_ai

# Redis (Celery task queue)
REDIS_URL=redis://localhost:6379/0

# GPU
CUDA_DEVICE=0
DEVICE=cuda   # cuda | cpu | mps (use mps on Apple Silicon)

# Model weights (download separately — see scripts/download_weights.sh)
YOLO_MODEL=yolov10x.pt
SAM2_MODEL=sam2_hiera_large.pt

# API Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
